{
  "name": "djangd-framework-storybook",
  "version": "0.1.0",
  "private": true,
  "description": "Storybook for djangd-framework — built and published to GitHub Pages.",
  "scripts": {
    "storybook": "npm run build:css && storybook dev -p 6006",
    "build:css": "sass ../djangd_framework/static/djangd/scss/djangd.scss ../djangd_framework/static/djangd/dist/djangd.css --no-source-map --style=compressed",
    "build": "npm run build:css && storybook build -o ../docs/storybook",
    "sync-django": "node ./scripts/sync-django.mjs"
  },
  "devDependencies": {
    "@storybook/addon-a11y": "^8.2.0",
    "@storybook/addon-essentials": "^8.2.0",
    "@storybook/addon-interactions": "^8.2.0",
    "@storybook/html": "^8.2.0",
    "@storybook/html-vite": "^8.2.0",
    "sass": "^1.77.0",
    "storybook": "^8.2.0",
    "vite": "^5.4.0"
  }
}
